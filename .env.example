# Copiá este archivo a .env.local en desarrollo.
# En Vercel: Project → Settings → Environment Variables (Production + Preview).

# ── Supabase (obligatorio) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── URL pública del sitio (producción: tu dominio Vercel o custom) ──
NEXT_PUBLIC_BASE_URL=

# ── PayPal (obligatorio para checkout) ──
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
# Producción: PAYPAL_ENV=live

# ── Brevo — emails transaccionales y arrepentimiento ──
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Buenos Productos
BREVO_LIST_COMPRADORES=
BREVO_LIST_REGISTRADOS=
BREVO_LIST_NEWSLETTER=

# ── Analytics (opcional) ──
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=

# ── Redes (opcional) ──
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# ── Google Sheets — pedidos legacy (opcional) ──
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_SHEET_NAME=Pedidos

# ── Webhooks / cron internos (opcional) ──
SYNC_ORDERS_SECRET=
BREVO_SYNC_SECRET=
SUPABASE_WEBHOOK_SECRET=

# ── Stripe (solo si usás /api/checkout con Stripe) ──
STRIPE_SECRET_KEY=
